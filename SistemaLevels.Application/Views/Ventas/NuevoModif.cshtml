@{
    ViewData["Title"] = "Ventas - Nuevo / Modificar";
    var id = (int)(ViewBag.Id ?? 0);
    var idCliente = (int)(ViewBag.IdCliente ?? 0);
}

@section Estilos {

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <link href="~/css/disenopantallas.css?v=1.0" rel="stylesheet" />
    <link href="~/css/VentasNuevoModif.css?v=1.0" rel="stylesheet" />

    <!-- Extras SOLO para la sección Contrato (tiles PDF/Word + layout) -->
  
}

<div class="container-fluid mt-4 ventanew">

    <!-- HEADER -->
    <div class="vn-card mb-3">
        <div class="vn-card-head">
            <div class="t">
                <i class="fa fa-ticket"></i>
                Ventas
            </div>

            <div class="vn-actions">

                <button class="btn btn-danger vn-btn" id="btnEliminarVenta" type="button">
                    <i class="fa fa-trash"></i> Eliminar venta
                </button>

                <button id="btnDraftSave" class="btn btn-outline-light vn-btn" type="button">
                    <i class="fa fa-save"></i> Guardar borrador
                </button>

                <div class="vn-actions-secondary">
                    <button id="btnDraftRestore" class="btn btn-info vn-btn" type="button">
                        <i class="fa fa-refresh"></i> Restaurar borrador
                    </button>

                    <button class="btn btn-warning vn-btn" id="btnDraftClear" type="button">
                        <i class="fa fa-trash"></i> Limpiar borrador
                    </button>
                </div>

                <button class="btn btn-primary vn-btn-main" id="btnGuardarVenta" type="button">
                    <i class="fa fa-check" id="tituloVenta"> Registrar venta</i>
                </button>

            </div>
        </div>
    </div>

    <div class="vn-grid">

        <!-- =======================
             FORMULARIO
        ======================= -->
        <div class="vn-card">

            <div class="vn-card-head vn-head-tabs">
                <ul class="vn-head-nav">
                    <li>
                        <button class="vn-head-btn active" data-sec="datos" type="button">
                            <i class="fa fa-info-circle"></i>
                            Datos de la venta
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="artistas" type="button">
                            <i class="fa fa-music"></i>
                            Artistas <span id="cntArtistas">(0)</span>
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="personal" type="button">
                            <i class="fa fa-id-badge"></i>
                            Personal <span id="cntPersonal">(0)</span>
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="cobros" type="button">
                            <i class="fa fa-money"></i>
                            Cobros <span id="cntCobros">(0)</span>
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="contrato" type="button">
                            <i class="fa fa-shield"></i>
                            Contrato
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="notas" type="button">
                            <i class="fa fa-sticky-note"></i>
                            Notas
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="resumenes" type="button">
                            <i class="fa fa-file-pdf-o"></i>
                            Resúmenes
                        </button>
                    </li>

                    <li>
                        <button class="vn-head-btn" data-sec="auditoria" type="button">
                            <i class="fa fa-shield"></i>
                            Auditoría
                        </button>
                    </li>
                </ul>
            </div>

            <div class="p-3">

                <input type="hidden" id="Venta_Id" value="@id" />
                <input type="hidden" id="Venta_IdCliente" value="@idCliente" />

                <!-- Formato elegido para exportar contrato (word/pdf) -->
                <input type="hidden" id="Contrato_Formato" value="pdf" />

                <!-- =====================
                     DATOS
                ===================== -->
                <div class="vn-section active" id="sec-datos">

                    <div id="errorCampos" class="rp-error-panel d-none mb-2">
                        <div class="rp-error-icon">
                            <i class="fa fa-exclamation-triangle"></i>
                        </div>

                        <div class="rp-error-content">
                            <div class="rp-error-title">No se pudo guardar</div>
                            <div class="rp-error-message"></div>
                        </div>

                        <button type="button"
                                class="rp-error-close"
                                onclick="cerrarErrorCampos()">
                            <i class="fa fa-times"></i>
                        </button>
                    </div>

                    <!-- ====== BLOQUE: DATOS GENERALES ====== -->
                    <div class="vn-subtitle">
                        <div class="i"><i class="fa fa-info-circle"></i></div>
                        <div class="txt">
                            <div class="t1">Datos de la venta</div>
                            <div class="t2">Completá la información principal del evento</div>
                        </div>
                    </div>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label vn-label">Cliente</label>
                            <select id="IdCliente" class="form-select vn-input"></select>
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Fecha</label>
                            <input type="date" id="Fecha" class="form-control vn-input" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Nombre evento</label>
                            <input id="NombreEvento" class="form-control vn-input" />
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Duración</label>
                            <input id="Duracion"
                                   type="text"
                                   class="form-control vn-input"
                                   placeholder="HH:MM"
                                   maxlength="5"
                                   inputmode="numeric">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Ubicación</label>
                            <select id="IdUbicacion" class="form-select vn-input"></select>
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Productora</label>
                            <select id="IdProductora" class="form-select vn-input"></select>
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Moneda</label>
                            <select id="IdMoneda" class="form-select vn-input"></select>
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label vn-label">Estado</label>
                            <select id="IdEstado" class="form-select vn-input"></select>
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Importe total</label>
                            <input id="ImporteTotal" class="form-control vn-input Inputmiles" type="text">
                            <div class="invalid-feedback">Campo obligatorio</div>
                        </div>

                    </div>


                </div>

                <!-- =====================
                     ARTISTAS
                ===================== -->
                <div class="vn-section" id="sec-artistas">

                    <button class="btn btn-outline-light vn-btn mb-2" id="btnAddArtista" type="button">
                        <i class="fa fa-plus"></i> Agregar artista
                    </button>

                    <div class="vn-gridtable">
                        <table class="table vn-table">
                            <thead>
                                <tr>
                                    <th>Artista</th>
                                    <th>Representante</th>
                                    <th>%</th>
                                    <th>Total comisión</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody id="tbArtistas"></tbody>
                        </table>
                    </div>

                </div>

                <!-- =====================
                     PERSONAL
                ===================== -->
                <div class="vn-section" id="sec-personal">

                    <button class="btn btn-outline-light vn-btn mb-2" id="btnAddPersonal" type="button">
                        <i class="fa fa-plus"></i> Agregar personal
                    </button>

                    <div class="vn-gridtable">
                        <table class="table vn-table">
                            <thead>
                                <tr>
                                    <th>Personal</th>
                                    <th>Cargo</th>
                                    <th>Tipo comisión</th>
                                    <th>%</th>
                                    <th>Total comisión</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody id="tbPersonal"></tbody>
                        </table>
                    </div>

                </div>

                <!-- =====================
                     COBROS
                ===================== -->
                <div class="vn-section" id="sec-cobros">

                    <button class="btn btn-outline-light vn-btn mb-2" id="btnAddCobro" type="button">
                        <i class="fa fa-plus"></i> Agregar cobro
                    </button>

                    <div class="vn-gridtable">
                        <table class="table vn-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Moneda</th>
                                    <th>Cuenta</th>
                                    <th>Importe</th>
                                    <th>Cotización</th>
                                    <th>Convertido</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody id="tbCobros"></tbody>
                        </table>
                    </div>

                </div>

                <div class="vn-section" id="sec-contrato">


                    <!-- ====== BLOQUE: CONTRATO ====== -->
                    <div class="vn-contract-wrap">

                        <div class="vn-subtitle" style="margin-top:0;">
                            <div class="i"><i class="fa fa-file-text-o"></i></div>
                            <div class="txt">
                                <div class="t1">Contrato</div>
                                <div class="t2">Definí condiciones y elegí formato de exportación</div>
                            </div>
                        </div>

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label vn-label">Tipo contrato</label>
                                <select id="IdTipoContrato" class="form-select vn-input"></select>
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label vn-label">Exclusividad</label>
                                <!-- PRECONFIG: Si=1 / No=2 -->
                                <select id="IdOpExclusividad" class="form-select vn-input">
                                    <option value="">Seleccionar...</option>
                                    <option value="1">Sí</option>
                                    <option value="2">No</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label vn-label">Días previos</label>
                                <input type="number" id="DiasPrevios" class="form-control vn-input" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label vn-label">Fecha hasta</label>
                                <input type="datetime-local" id="FechaHasta" class="form-control vn-input" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label vn-label">Formato</label>

                                <div class="vn-contract-tiles">

                                    <!-- WORD -->
                                    <label class="vn-contract-tile" id="tileWord" data-formato="word">
                                        <div class="ico word">
                                            <i class="fa fa-file-word-o"></i>
                                        </div>
                                        <div class="txt">
                                            <div class="t1">Word</div>
                                            <div class="t2">.docx editable</div>
                                        </div>
                                        <input type="radio" name="ContratoFormato" value="word" />
                                    </label>

                                    <!-- PDF -->
                                    <label class="vn-contract-tile is-selected" id="tilePdf" data-formato="pdf">
                                        <div class="ico pdf">
                                            <i class="fa fa-file-pdf-o"></i>
                                        </div>
                                        <div class="txt">
                                            <div class="t1">PDF</div>
                                            <div class="t2">Documento final</div>
                                        </div>
                                        <input type="radio" name="ContratoFormato" value="pdf" checked />
                                    </label>

                                </div>

                                <div class="mt-2 small" style="opacity:.75;">
                                    Tip: podés cambiar el formato acá; el botón “Generar contrato” lo usa directamente.
                                </div>
                            </div>

                            <div class="col-12 d-flex gap-2 flex-wrap mt-1">
                                <button class="btn btn-success vn-btn" id="btnContrato" type="button">
                                    <i class="fa fa-file-text-o"></i>
                                    Generar contrato
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- =====================
                     NOTAS
                ===================== -->
                <div class="vn-section" id="sec-notas">

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label vn-label">Nota interna</label>
                            <textarea id="NotaInterna" class="form-control vn-input" rows="4"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label vn-label">Nota cliente</label>
                            <textarea id="NotaCliente" class="form-control vn-input" rows="4"></textarea>
                        </div>
                    </div>

                </div>

                <div class="vn-section" id="sec-resumenes">

                    <div class="vn-subtitle">
                        <div class="i"><i class="fa fa-file-pdf-o"></i></div>
                        <div class="txt">
                            <div class="t1">Resúmenes de la venta</div>
                            <div class="t2">Exportá documentos financieros de la operación</div>
                        </div>
                    </div>

                    <div class="vn-resumen-grid">

                        <div class="vn-resumen-card" id="btnResumenComisiones">
                            <div class="icon">
                                <i class="fa fa-line-chart"></i>
                            </div>

                            <div class="content">
                                <div class="title">Resumen de comisiones</div>
                                <div class="desc">
                                    Detalle de comisiones por artista y personal
                                </div>
                            </div>

                            <div class="action">
                                <i class="fa fa-download"></i>
                            </div>
                        </div>

                        <div class="vn-resumen-card" id="btnResumenCliente">
                            <div class="icon">
                                <i class="fa fa-user"></i>
                            </div>

                            <div class="content">
                                <div class="title">Resumen cliente</div>
                                <div class="desc">
                                    Información financiera para el cliente
                                </div>
                            </div>

                            <div class="action">
                                <i class="fa fa-download"></i>
                            </div>
                        </div>

                    </div>

                </div>

                <!-- =====================
                     AUDITORIA
                ===================== -->
                <div class="vn-section" id="sec-auditoria">
                    <div id="audReg"></div>
                    <div id="audMod"></div>
                </div>

            </div>
        </div>

        <!-- =======================
             RESUMEN FINANCIERO
        ======================= -->
        <div class="vn-card">

            <div class="vn-card-head">
                <div class="t">
                    <i class="fa fa-line-chart"></i>
                    Resumen financiero
                </div>
            </div>

            <div class="p-3 vn-summary">

                <div class="vn-stat">
                    <div class="lbl">Importe total</div>
                    <div class="val" id="sumImporte">$ 0</div>
                </div>

                <div class="vn-stat">
                    <div class="lbl">Total comisiones</div>
                    <div class="val" id="sumComisiones">$ 0</div>
                </div>

                <div class="vn-stat">
                    <div class="lbl">Cobrado</div>
                    <div class="val" id="sumCobrado">$ 0</div>
                </div>

                <div class="vn-stat">
                    <div class="lbl">Saldo</div>
                    <div class="val" id="sumSaldo">$ 0</div>
                </div>

            </div>

        </div>

    </div>

</div>

<!-- =========================
     MODAL EXPORTAR CONTRATO
========================= -->
<div class="modal fade vn-export-modal" id="modalExportarContrato" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content vn-export-card">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-file-text-o"></i>
                    Exportar contrato
                </h5>

                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="vn-export-desc">
                    Elegí el formato en el que querés descargar el contrato.
                </p>

                <div class="vn-export-options">

                    <!-- WORD -->
                    <button class="vn-export-option"
                            data-tipo="word"
                            id="btnExportWord"
                            type="button">

                        <div class="icon word">
                            <i class="fa fa-file-word-o"></i>
                        </div>

                        <div class="text">
                            <div class="title">Word</div>
                            <div class="sub">.docx editable</div>
                        </div>

                    </button>

                    <!-- PDF -->
                    <button class="vn-export-option"
                            data-tipo="pdf"
                            id="btnExportPdf"
                            type="button">

                        <div class="icon pdf">
                            <i class="fa fa-file-pdf-o"></i>
                        </div>

                        <div class="text">
                            <div class="title">PDF</div>
                            <div class="sub">Documento final</div>
                        </div>

                    </button>

                </div>

            </div>

        </div>
    </div>
</div>

<partial name="~/Views/Utils/Modals.cshtml" />

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/pizzip@3.1.5/dist/pizzip.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/docxtemplater@3.37.9/build/docxtemplater.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/docx-preview@0.3.4/dist/docx-preview.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>

    <script src="https://unpkg.com/mammoth/mammoth.browser.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

    <!-- moment -->
    <script src="~/js/utils/moment.js"></script>

    <script>
        window.VN_INIT = {
            id: @id,
            idCliente: @idCliente
        };

   
    </script>

    <script src="~/js/VentasNuevoModif.js?v=1.0"></script>

}