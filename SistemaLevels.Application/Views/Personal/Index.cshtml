@{
    ViewData["Title"] = "Personal";
}

@section Estilos {
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.2.2/css/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/fixedheader/3.2.2/css/fixedHeader.dataTables.min.css" rel="stylesheet" />

    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Estilos -->
    <link href="~/css/Personal.css" rel="stylesheet" />
    <link href="~/css/Productora.css" rel="stylesheet" />
    <link href="~/css/disenopantallas.css?v=1.0" rel="stylesheet" />
}

<div class="container-fluid mt-5">

    <div class="container page-99" style="margin-top:40px">

        <!-- HEADER -->
        <div class="cc-header shadow-lg rounded-4 p-4 mb-4">

            <div class="d-flex align-items-center gap-3 flex-wrap">

                <div class="d-flex align-items-center gap-3">
                    <span class="cc-badge">
                        <i class="fa fa-users"></i>
                    </span>

                    <div>
                        <h2 class="m-0 fw-800">Personal</h2>
                        <small class="text-muted-cc">Gestión de personal</small>
                    </div>
                </div>

                <div class="ms-auto d-flex gap-4 flex-wrap align-items-center">

                    <div class="cc-stat">
                        <div class="label">Personal</div>
                        <div class="value">
                            <strong id="kpiCantPersonal">0</strong>
                        </div>
                    </div>

                    <!-- CONFIG COLUMNAS -->
                    <div class="dropdown cc-dd">
                        <button class="btn btn-secondary dropdown-toggle"
                                type="button"
                                id="dropdownColumnas"
                                data-bs-toggle="dropdown"
                                data-bs-display="static"
                                data-bs-auto-close="outside">

                            <i class="fa fa-cog me-2"></i> Config. Columnas
                        </button>

                        <ul class="dropdown-menu cc-dropdown-menu"
                            id="configColumnasMenu"></ul>
                    </div>

                    <!-- NUEVO -->
                    <button class="btn btn-success d-flex align-items-center px-3 py-2 btnnuevo"
                            onclick="nuevoPersonal()">
                        <i class="fa fa-plus-square me-2"></i> Nuevo
                    </button>

                </div>
            </div>
        </div>

        <!-- CARD -->
        <div class="card-glass p-3">

            <!-- =========================
                 FILTROS
            ========================= -->

            <div class="rp-filtros-wrap mb-3">

                <div class="rp-filtros-head"
                     data-bs-toggle="collapse"
                     data-bs-target="#panelFiltrosPersonal"
                     aria-expanded="false">

                    <div class="title">
                        <i class="fa fa-filter"></i>
                        <span>Filtros</span>

                        <small class="text-muted-cc"
                               id="txtFiltrosEstadoPersonal"
                               style="margin-left:8px;">
                        </small>
                    </div>

                    <i class="fa fa-chevron-down chev"></i>
                </div>

                <div id="panelFiltrosPersonal" class="collapse">

                    <div class="rp-filtros-body">

                        <div class="row g-3">

                            <div class="col-md-3">
                                <div class="rp-filter-label">Nombre contiene</div>
                                <input type="text"
                                       id="fNombre"
                                       class="rp-filter-input"
                                       placeholder="Ej: Juan..." />
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">País</div>
                                <select id="fPais" class="rp-filter-select select2"></select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Tipo Documento</div>
                                <select id="fTipoDocumento" class="rp-filter-select select2"></select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Condición IVA</div>
                                <select id="fCondicionIva" class="rp-filter-select select2"></select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Rol asignado</div>
                                <select id="fRol" class="rp-filter-select select2"></select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Artista asignado</div>
                                <select id="fArtista" class="rp-filter-select select2"></select>
                            </div>

                        </div>

                        <div class="rp-filtros-actions mt-3">

                            <button class="btn btn-outline-light"
                                    type="button"
                                    onclick="limpiarFiltrosPersonal()">
                                <i class="fa fa-eraser"></i> Limpiar
                            </button>

                            <button class="btn btn-primary"
                                    type="button"
                                    onclick="aplicarFiltrosPersonal()">
                                <i class="fa fa-check"></i> Aplicar
                            </button>

                        </div>

                    </div>
                </div>
            </div>

            <!-- GRID -->

            <div class="dt-dark-wrap">

                <table class="dt-dark display nowrap compact"
                       id="grd_Personal"
                       style="width:100%">

                    <thead>
                        <tr>
                            <th></th>
                            <th>Nombre</th>
                            <th>País</th>
                            <th>Dni</th>
                            <th>Tipo Doc</th>
                            <th>Nro Doc</th>
                            <th>Condición IVA</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                        </tr>
                    </thead>

                    <tbody></tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<div id="modalPersonalHost"></div>

<!-- MODAL GENERICO -->
<partial name="~/Views/Utils/Modals.cshtml" />
<partial name="~/Views/Entities/M_Personal.cshtml" />

@section Scripts {

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <!-- Buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <!-- Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


    <!-- SCRIPT PRINCIPAL -->
    <script src="~/js/Personal.js?v=2.0"></script>

}