<!-- MISMO ESTILO CLIENTES -->
<link href="~/css/productora.css?v=1.0" rel="stylesheet" />
<link href="~/css/disenopantallas.css?v=1.0" rel="stylesheet" />
<link href="~/css/M_Generico.css" rel="stylesheet" />
@* =========================================================
   m_personal.cshtml
   Modal genérico reutilizable de Personal
   ========================================================= *@
<div class="modal fade personal-modal-root"
     data-personal-modal="personal"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">

    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header colorEncabezado">

                <h5 class="modal-title fw-bold"
                    id="modalEdicionLabel">

                    Nuevo Personal

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <div id="errorCampos"
                     class="rp-error-panel d-none mb-2">

                    <div class="rp-error-icon">
                        <i class="fa fa-exclamation-triangle"></i>
                    </div>

                    <div class="rp-error-content">

                        <div class="rp-error-title">
                            No se pudo guardar
                        </div>

                        <div class="rp-error-message"></div>

                    </div>

                    <button type="button"
                            class="rp-error-close"
                            onclick="cerrarErrorCampos()">

                        <i class="fa fa-times"></i>

                    </button>

                </div>


                <!-- NAV TABS -->

                <ul class="nav rp-tabs-modern mb-3"
                    id="personalTabs">

                    <li class="nav-item">

                        <button class="nav-link active"
                                data-bs-toggle="tab"
                                data-bs-target="#tabDatos">

                            <i class="fa fa-user"></i>
                            Datos del Personal

                        </button>

                    </li>


                    <li class="nav-item">

                        <button class="nav-link"
                                data-bs-toggle="tab"
                                data-bs-target="#tabRoles">

                            <i class="fa fa-id-badge"></i>

                            Roles asignados

                            <span id="contadorRoles"
                                  class="rp-tab-count">(0)</span>

                        </button>

                    </li>


                    <li class="nav-item d-none"
                        id="tabArtistasBtn">

                        <button class="nav-link"
                                data-bs-toggle="tab"
                                data-bs-target="#tabArtistas">

                            <i class="fa fa-music"></i>

                            Artistas asignados

                            <span id="contadorArtistas"
                                  class="rp-tab-count">(0)</span>

                        </button>

                    </li>

                </ul>



                <div class="tab-content">

                    <!-- TAB DATOS -->

                    <div class="tab-pane fade show active"
                         id="tabDatos">

                        <form class="row g-3">

                            <input type="text"
                                   id="txtId"
                                   hidden>


                            <div class="col-md-6">

                                <label class="form-label">
                                    Nombre
                                </label>

                                <input id="txtNombre"
                                       class="form-control"
                                       required>

                                <div class="invalid-feedback">
                                    Campo obligatorio
                                </div>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    País
                                </label>

                                <select id="cmbPais"
                                        class="form-control"></select>

                                <div class="invalid-feedback">
                                    Campo obligatorio
                                </div>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Dni
                                </label>

                                <input id="txtDni"
                                       class="form-control">

                                <div class="invalid-feedback">
                                    Campo obligatorio
                                </div>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Tipo Documento
                                </label>

                                <select id="cmbTipoDocumento"
                                        class="form-control"></select>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Número Documento
                                </label>

                                <input id="txtNumeroDocumento"
                                       class="form-control">

                                <div class="invalid-feedback">
                                    Campo obligatorio
                                </div>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Condición IVA
                                </label>

                                <select id="cmbCondicionIva"
                                        class="form-control"></select>

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Fecha Nacimiento
                                </label>

                                <input id="txtFechaNacimiento"
                                       type="date"
                                       class="form-control">

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Teléfono
                                </label>

                                <input id="txtTelefono"
                                       class="form-control">

                            </div>



                            <div class="col-md-6">

                                <label class="form-label">
                                    Email
                                </label>

                                <input id="txtEmail"
                                       class="form-control">

                            </div>



                            <div class="col-md-12">

                                <label class="form-label">
                                    Dirección
                                </label>

                                <input id="txtDireccion"
                                       class="form-control">

                            </div>


                        </form>

                    </div>



                    <!-- TAB ROLES -->

                    <div class="tab-pane fade"
                         id="tabRoles">

                        <div id="listaRoles"
                             class="rp-checklist"></div>

                    </div>



                    <!-- TAB ARTISTAS -->

                    <div class="tab-pane fade"
                         id="tabArtistas">


                        <div id="listaArtistas"
                             class="rp-checklist"></div>


                        <div class="rp-auto-card mt-3">


                            <div class="rp-auto-left">


                                <div class="rp-auto-icon">
                                    <i class="fa fa-link"></i>
                                </div>


                                <div class="rp-auto-text">

                                    <div class="rp-auto-title">
                                        Asociación automática de productoras
                                    </div>

                                    <div class="rp-auto-desc">
                                        Las productoras principales se asignarán automáticamente al cliente.
                                    </div>

                                </div>

                            </div>



                            <label class="rp-switch">

                                <input type="checkbox"
                                       id="chkAsociacionAutomatica">

                                <span class="rp-slider"></span>

                            </label>


                        </div>


                    </div>


                </div>



                <!-- AUDITORÍA -->

                <div class="rp-auditoria d-none mt-3"
                     id="infoAuditoria">

                    <div id="infoRegistro"></div>

                    <div id="infoModificacion"></div>

                </div>


            </div>



            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    <i class="fa fa-arrow-left"></i>
                    Volver

                </button>


                <button id="btnGuardar"
                        class="btn btn-primary"
                        onclick="guardarPersonal()">

                    <i class="fa fa-check"></i>
                    Registrar

                </button>

            </div>

        </div>

    </div>

</div>

<script src="~/js/entities/M_Personal.js"></script>