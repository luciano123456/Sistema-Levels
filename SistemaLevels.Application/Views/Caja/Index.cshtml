@{
    ViewData["Title"] = "Caja";
}

@section Estilos {
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.2.2/css/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/fixedheader/3.2.2/css/fixedHeader.dataTables.min.css" rel="stylesheet" />

    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Estilos base -->
    <link href="~/css/Caja.css?v=1.0" rel="stylesheet" />
    <link href="~/css/disenopantallas.css?v=1.0" rel="stylesheet" />
}

<div class="container-fluid mt-4 ventas-index">

    <!-- HEADER -->
    <div class="vi-header cc-header shadow-lg rounded-4 p-3 mb-3">
        <div class="d-flex align-items-center gap-3 flex-wrap">

            <span class="cc-badge">
                <i class="fa fa-bank"></i>
            </span>

            <div>
                <h2 class="m-0 fw-800">Caja</h2>
                <small class="text-muted-cc">
                    Tesorería • movimientos • transferencias
                </small>
            </div>

            <div class="ms-auto d-flex gap-2 flex-wrap">

                <button id="btnRefreshCaja" class="btn btn-outline-light vi-btn" type="button">
                    <i class="fa fa-refresh me-2"></i> Actualizar
                </button>

                <button id="btnIngreso" class="btn btn-success vi-btn" type="button">
                    <i class="fa fa-plus me-2"></i> Ingreso
                </button>

                <button id="btnEgreso" class="btn btn-danger vi-btn" type="button">
                    <i class="fa fa-minus me-2"></i> Egreso
                </button>

                <button id="btnTransferencia" class="btn btn-warning vi-btn" type="button">
                    <i class="fa fa-exchange me-2"></i> Transferencia
                </button>

            </div>
        </div>
    </div>

    <div class="cc-card">

        <div class="cc-card-body">

            <!-- FILTROS -->
            <div class="rp-filtros-wrap mb-3">

                <div class="rp-filtros-head"
                     data-bs-toggle="collapse"
                     data-bs-target="#panelFiltrosCaja"
                     aria-expanded="false">

                    <div class="title">
                        <i class="fa fa-filter"></i>
                        <span>Filtros</span>
                        <small class="text-muted-cc"
                               id="txtFiltrosEstadoCaja"
                               style="margin-left:8px;"></small>
                    </div>

                    <i class="fa fa-chevron-down chev"></i>
                </div>

                <!-- plegado por defecto -->
                <div id="panelFiltrosCaja" class="collapse">
                    <div class="rp-filtros-body">

                        <div class="row g-3">

                            <div class="col-md-2">
                                <div class="rp-filter-label">Fecha desde</div>
                                <input type="date"
                                       id="fFechaDesde"
                                       class="rp-filter-input" />
                            </div>

                            <div class="col-md-2">
                                <div class="rp-filter-label">Fecha hasta</div>
                                <input type="date"
                                       id="fFechaHasta"
                                       class="rp-filter-input" />
                            </div>

                            <div class="col-md-2">
                                <div class="rp-filter-label">Moneda</div>
                                <select id="fMoneda"
                                        class="rp-filter-select select2"
                                        style="width:100%">
                                </select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Cuenta</div>
                                <select id="fCuenta"
                                        class="rp-filter-select select2"
                                        style="width:100%">
                                </select>
                            </div>

                            <div class="col-md-3">
                                <div class="rp-filter-label">Tipo</div>
                                <select id="fTipo"
                                        class="rp-filter-select select2"
                                        style="width:100%">
                                    <option value="">Todos</option>
                                    <option value="INGRESO MANUAL">Ingreso manual</option>
                                    <option value="EGRESO MANUAL">Egreso manual</option>
                                    <option value="TRANSFERENCIA">Transferencia</option>
                                    <option value="COBRO">Cobro</option>
                                    <option value="PAGO ARTISTA">Pago artista</option>
                                    <option value="PAGO PERSONAL">Pago personal</option>
                                    <option value="PAGO PERSONAL">Pago personal</option>
                                    <option value="AJUSTE">Ajuste</option>
                                </select>
                            </div>

                            <div class="col-md-12">
                                <div class="rp-filter-label">Concepto contiene</div>
                                <input type="text"
                                       id="fTexto"
                                       class="rp-filter-input"
                                       placeholder="Buscar por concepto..." />
                            </div>

                        </div>

                        <div class="rp-filtros-actions mt-3">

                            <button class="btn btn-outline-light"
                                    type="button"
                                    onclick="limpiarFiltrosCaja()">
                                <i class="fa fa-eraser"></i> Limpiar
                            </button>

                            <button class="btn btn-primary"
                                    type="button"
                                    onclick="aplicarFiltrosCaja()">
                                <i class="fa fa-check"></i> Aplicar
                            </button>

                        </div>

                    </div>
                </div>
            </div>

            <!-- KPIS -->
            <div class="cc-kpis">

                <div class="cc-kpi">
                    <div class="lbl">Saldo anterior</div>
                    <div class="val" id="kpiSaldoAnterior">$ 0</div>
                </div>

                <div class="cc-kpi">
                    <div class="lbl">Ingresos</div>
                    <div class="val" id="kpiIngresos">$ 0</div>
                </div>

                <div class="cc-kpi">
                    <div class="lbl">Egresos</div>
                    <div class="val" id="kpiEgresos">$ 0</div>
                </div>

                <div class="cc-kpi">
                    <div class="lbl">Saldo actual</div>
                    <div class="val" id="kpiSaldoActual">$ 0</div>
                </div>

                <div class="cc-kpi">
                    <div class="lbl">Movimientos</div>
                    <div class="val" id="kpiMovimientos">0</div>
                </div>

            </div>

            <!-- TOOLBAR -->
            <div class="cc-toolbar mb-2">

                <div class="cc-toolbar-actions">
                    <div id="chipCajaEstado" class="cc-balance-chip warn">
                        <i class="fa fa-line-chart"></i>
                        Sin datos
                    </div>
                </div>

                <div class="dropdown cc-dd">
                    <button class="btn btn-secondary dropdown-toggle"
                            type="button"
                            id="dropdownColumnasCaja"
                            data-bs-toggle="dropdown"
                            data-bs-display="static"
                            data-bs-auto-close="outside">
                        <i class="fa fa-cog me-2"></i> Config. Columnas
                    </button>

                    <ul class="dropdown-menu cc-dropdown-menu"
                        id="configColumnasMenuCaja"></ul>
                </div>

            </div>

            <!-- TABLA -->
            <div class="dt-dark-wrap">
                <table class="dt-dark display nowrap compact"
                       id="grd_Caja"
                       style="width:100%">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Origen</th>
                           
                            <th>Moneda</th>
                            <th>Cuenta</th>
                            <th>Concepto</th>
                            <th>Ingreso</th>
                            <th>Egreso</th>
                            <th>Saldo</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- =========================
     MODAL INGRESO
========================= -->
<div class="modal fade"
     id="modalIngreso"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header colorEncabezado">
                <h5 class="modal-title fw-bold" id="modalIngresoLabel">
                    Ingreso manual
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="iId" />

                <div id="errorCamposIngreso" class="rp-error-panel d-none mb-2">
                    <div class="rp-error-icon">
                        <i class="fa fa-exclamation-triangle"></i>
                    </div>

                    <div class="rp-error-content">
                        <div class="rp-error-title">No se pudo guardar</div>
                        <div class="rp-error-message"></div>
                    </div>

                    <button type="button"
                            class="rp-error-close"
                            onclick="cerrarErrorCamposIngreso()">
                        <i class="fa fa-times"></i>
                    </button>
                </div>

                <form class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Fecha</label>
                        <input id="iFecha" type="date" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Moneda</label>
                        <select id="iMoneda" class="form-control"></select>
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Cuenta</label>
                        <select id="iCuenta" class="form-control"></select>
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Importe</label>
                        <input id="iImporte" type="number" min="0" step="0.01" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Concepto</label>
                        <input id="iConcepto" class="form-control" placeholder="Ej: ingreso manual, refuerzo de caja...">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                </form>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    <i class="fa fa-arrow-left"></i> Volver
                </button>

                <button id="btnGuardarIngreso"
                        class="btn btn-primary"
                        onclick="guardarIngreso()"
                        type="button">
                    <i class="fa fa-check"></i> Registrar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- =========================
     MODAL EGRESO
========================= -->
<div class="modal fade"
     id="modalEgreso"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header colorEncabezado">
                <h5 class="modal-title fw-bold" id="modalEgresoLabel">
                    Egreso manual
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="eId" />

                <div id="errorCamposEgreso" class="rp-error-panel d-none mb-2">
                    <div class="rp-error-icon">
                        <i class="fa fa-exclamation-triangle"></i>
                    </div>

                    <div class="rp-error-content">
                        <div class="rp-error-title">No se pudo guardar</div>
                        <div class="rp-error-message"></div>
                    </div>

                    <button type="button"
                            class="rp-error-close"
                            onclick="cerrarErrorCamposEgreso()">
                        <i class="fa fa-times"></i>
                    </button>
                </div>

                <form class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Fecha</label>
                        <input id="eFecha" type="date" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Moneda</label>
                        <select id="eMoneda" class="form-control"></select>
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Cuenta</label>
                        <select id="eCuenta" class="form-control"></select>
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Importe</label>
                        <input id="eImporte" type="number" min="0" step="0.01" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Concepto</label>
                        <input id="eConcepto" class="form-control" placeholder="Ej: gasto manual, retiro, ajuste...">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                </form>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    <i class="fa fa-arrow-left"></i> Volver
                </button>

                <button id="btnGuardarEgreso"
                        class="btn btn-primary"
                        onclick="guardarEgreso()"
                        type="button">
                    <i class="fa fa-check"></i> Registrar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- =========================
     MODAL TRANSFERENCIA
========================= -->
<div class="modal fade"
     id="modalTransferencia"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header colorEncabezado">
                <h5 class="modal-title fw-bold" id="modalTransferenciaLabel">
                    Transferencia entre cuentas
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="tId" />

                <div id="errorCamposTransferencia" class="rp-error-panel d-none mb-2">
                    <div class="rp-error-icon">
                        <i class="fa fa-exclamation-triangle"></i>
                    </div>

                    <div class="rp-error-content">
                        <div class="rp-error-title">No se pudo guardar</div>
                        <div class="rp-error-message"></div>
                    </div>

                    <button type="button"
                            class="rp-error-close"
                            onclick="cerrarErrorCamposTransferencia()">
                        <i class="fa fa-times"></i>
                    </button>
                </div>

                <form class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Fecha</label>
                        <input id="tFecha" type="date" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Cotización</label>
                        <input id="tCotizacion" type="number" min="0" step="0.0001" class="form-control">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Nota interna</label>
                        <input id="tNota" class="form-control" placeholder="Ej: transferencia entre cuentas, pase interno...">
                        <div class="invalid-feedback">Campo obligatorio</div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <h6 class="mb-3">Origen</h6>

                            <div class="mb-3">
                                <label class="form-label">Moneda origen</label>
                                <select id="tMonedaOrigen" class="form-control"></select>
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Cuenta origen</label>
                                <select id="tCuentaOrigen" class="form-control"></select>
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>

                            <div>
                                <label class="form-label">Importe origen</label>
                                <input id="tImporteOrigen" type="number" min="0" step="0.01" class="form-control">
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <h6 class="mb-3">Destino</h6>

                            <div class="mb-3">
                                <label class="form-label">Moneda destino</label>
                                <select id="tMonedaDestino" class="form-control"></select>
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Cuenta destino</label>
                                <select id="tCuentaDestino" class="form-control"></select>
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>

                            <div>
                                <label class="form-label">Importe destino</label>
                                <input id="tImporteDestino" type="number" min="0" step="0.01" class="form-control">
                                <div class="invalid-feedback">Campo obligatorio</div>
                            </div>
                        </div>
                    </div>

                </form>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    <i class="fa fa-arrow-left"></i> Volver
                </button>

                <button id="btnGuardarTransferencia"
                        class="btn btn-primary"
                        onclick="guardarTransferencia()"
                        type="button">
                    <i class="fa fa-check"></i> Registrar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- =========================
     MODAL VER MOVIMIENTO
========================= -->
<div class="modal fade"
     id="modalVerMovimiento"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">

    <div class="modal-dialog modal-lg modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header colorEncabezado">
                <h5 class="modal-title fw-bold">
                    Detalle del movimiento
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="cc-view-grid">

                    <div class="cc-view-item">
                        <div class="k">Fecha</div>
                        <div class="v" id="vmFecha"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Tipo</div>
                        <div class="v" id="vmTipo"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Origen</div>
                        <div class="v" id="vmOrigen"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Cuenta</div>
                        <div class="v" id="vmCuenta"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Moneda</div>
                        <div class="v" id="vmMoneda"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Concepto</div>
                        <div class="v" id="vmConcepto"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Ingreso</div>
                        <div class="v" id="vmIngreso"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Egreso</div>
                        <div class="v" id="vmEgreso"></div>
                    </div>

                    <div class="cc-view-item">
                        <div class="k">Saldo</div>
                        <div class="v" id="vmSaldo"></div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    <i class="fa fa-check"></i> Cerrar
                </button>

            </div>

        </div>
    </div>
</div>

<partial name="~/Views/Utils/Modals.cshtml" />

@section Scripts {
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <!-- DataTables Buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>

    <!-- Dependencias exportación -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <!-- Botones HTML5 -->
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <!-- fixedHeader -->
    <script src="https://cdn.datatables.net/fixedheader/3.2.2/js/dataTables.fixedHeader.min.js"></script>

    <!-- select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- moment -->
    <script src="~/js/utils/moment.js"></script>

    <!-- tu JS -->
    <script src="~/js/Caja.js?v=1.0"></script>
}